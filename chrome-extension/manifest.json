{
  "manifest_version": 3,
  "name": "ExtractResume AI",
  "version": "1.2.0",
  "description": "AI-powered LinkedIn job scraper and resume skill gap analyzer.",
  "permissions": [
    "activeTab", 
    "scripting", 
    "tabs", 
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/search/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:8000"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "dashboard.js" , "chart.js"],
      "matches": ["<all_urls>"]
    }
  ]
}