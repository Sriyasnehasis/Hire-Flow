# ExtractResume AI - Environment Configuration
# Copy this file to .env and fill in your values

# ============== APP SETTINGS ==============
DEBUG=True
ENVIRONMENT=development

# ============== DATABASE ==============
POSTGRES_USER=extractresume_user
POSTGRES_PASSWORD=extractresume_password
POSTGRES_DB=extractresume_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://extractresume_user:extractresume_password@postgres:5432/extractresume_db

MONGO_USER=extractresume
MONGO_PASSWORD=extractresume_password
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_URL=mongodb://extractresume:extractresume_password@mongodb:27017

REDIS_URL=redis://redis:6379

# ============== SECURITY ==============
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============== EMAIL SETTINGS ==============
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ============== AWS S3 (File Storage) ==============
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=extractresume-files
AWS_REGION=us-east-1

# ============== EXTERNAL API KEYS ==============
# OpenAI API Key (for GPT, interview prep, cover letters)
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Adzuna Job API (for job listings)
ADZUNA_API_KEY=your-adzuna-api-key
ADZUNA_APP_ID=your-adzuna-app-id

# LinkedIn (for contact scraping)
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# GitHub (for profile integration)
GITHUB_TOKEN=ghp_your-github-token

# ============== SERVICE PORTS ==============
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
MONGO_PORT=27017
REDIS_PORT=6379

# ============== CORS ==============
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============== LOGGING ==============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============== FEATURE FLAGS ==============
ENABLE_LINKEDIN_SCRAPING=False
ENABLE_EMAIL_VERIFICATION=False
ENABLE_GITHUB_INTEGRATION=True
ENABLE_AI_FEATURES=True
